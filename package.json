{
    "name":  "kone-digital",
    "private":  true,
    "version":  "0.0.0",
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "tsc \u0026\u0026 vite build",
                    "postbuild":  "react-snap",
                    "lint":  "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
                    "preview":  "vite preview",
                    "predeploy":  "npm run build",
                    "deploy":  "gh-pages -d dist --dotfiles"
                },
    "dependencies":  {
                         "firebase":  "^12.12.1",
                         "react":  "^18.2.0",
                         "react-dom":  "^18.2.0"
                     },
    "devDependencies":  {
                            "@types/react":  "^18.2.66",
                            "@types/react-dom":  "^18.2.22",
                            "@vitejs/plugin-react":  "^4.2.1",
                            "gh-pages":  "^6.3.0",
                            "react-snap":  "^1.23.0",
                            "typescript":  "^5.2.2",
                            "vite":  "^5.2.0"
                        },
    "reactSnap":  {
                      "source":  "dist",
                      "puppeteerArgs":  [
                                            "--no-sandbox",
                                            "--disable-setuid-sandbox"
                                        ]
                  },
    "overrides":  {
                      "react-snap":  {
                                         "puppeteer":  "^22.0.0"
                                     }
                  }
}
